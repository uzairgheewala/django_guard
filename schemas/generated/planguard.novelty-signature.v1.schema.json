{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "schema_version": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        }
      },
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_hash",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "NoveltySignaturePayload": {
      "additionalProperties": false,
      "properties": {
        "corpus_size": {
          "default": 0,
          "minimum": 0,
          "title": "Corpus Size",
          "type": "integer"
        },
        "distance": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Distance"
        },
        "explanation": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Explanation",
          "type": "array"
        },
        "feature_vector": {
          "additionalProperties": true,
          "title": "Feature Vector",
          "type": "object"
        },
        "nearest_signature_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Nearest Signature Refs",
          "type": "array"
        },
        "novel_dimensions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Novel Dimensions",
          "type": "array"
        },
        "signature_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Signature Hash",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/NoveltyStatus"
        },
        "subject_ref": {
          "$ref": "#/$defs/ArtifactReference"
        }
      },
      "required": [
        "corpus_size",
        "distance",
        "explanation",
        "feature_vector",
        "nearest_signature_refs",
        "novel_dimensions",
        "signature_hash",
        "status",
        "subject_ref"
      ],
      "title": "NoveltySignaturePayload",
      "type": "object"
    },
    "NoveltyStatus": {
      "enum": [
        "novel",
        "known",
        "partial",
        "not_evaluated"
      ],
      "title": "NoveltyStatus",
      "type": "string"
    },
    "ProducerIdentity": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Build"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "build",
        "name",
        "version"
      ],
      "title": "ProducerIdentity",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "code_revision": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Revision"
        },
        "configuration_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivation_key": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Key"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "code_revision",
        "configuration_ref",
        "derivation_key",
        "input_refs",
        "notes"
      ],
      "title": "Provenance",
      "type": "object"
    }
  },
  "$id": "https://planguard.dev/schemas/planguard.novelty-signature.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_kind": {
      "const": "novelty_signature",
      "default": "novelty_signature",
      "title": "Artifact Kind",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Extensions",
      "type": "object"
    },
    "payload": {
      "$ref": "#/$defs/NoveltySignaturePayload"
    },
    "producer": {
      "$ref": "#/$defs/ProducerIdentity"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "planguard.novelty-signature.v1",
      "default": "planguard.novelty-signature.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "content_hash",
    "created_at",
    "extensions",
    "payload",
    "producer",
    "provenance",
    "schema_version"
  ],
  "title": "NoveltySignatureArtifact",
  "type": "object"
}
