{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "schema_version": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        }
      },
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_hash",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "BenchmarkSample": {
      "additionalProperties": false,
      "properties": {
        "analysis_run_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "case_key": {
          "title": "Case Key",
          "type": "string"
        },
        "completed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completed At"
        },
        "dimensions": {
          "additionalProperties": true,
          "title": "Dimensions",
          "type": "object"
        },
        "excluded_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Excluded Reason"
        },
        "iteration": {
          "minimum": 0,
          "title": "Iteration",
          "type": "integer"
        },
        "metrics": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Metrics",
          "type": "object"
        },
        "scenario_run_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "started_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Started At"
        },
        "valid": {
          "default": true,
          "title": "Valid",
          "type": "boolean"
        },
        "warmup": {
          "default": false,
          "title": "Warmup",
          "type": "boolean"
        }
      },
      "required": [
        "analysis_run_ref",
        "case_key",
        "completed_at",
        "dimensions",
        "excluded_reason",
        "iteration",
        "metrics",
        "scenario_run_ref",
        "started_at",
        "valid",
        "warmup"
      ],
      "title": "BenchmarkSample",
      "type": "object"
    },
    "BenchmarkStatus": {
      "enum": [
        "created",
        "running",
        "completed",
        "degraded",
        "failed"
      ],
      "title": "BenchmarkStatus",
      "type": "string"
    },
    "ExperimentSeriesPayload": {
      "additionalProperties": false,
      "properties": {
        "capability_gaps": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Capability Gaps",
          "type": "array"
        },
        "comparability_notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Comparability Notes",
          "type": "array"
        },
        "distributions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/MetricDistribution"
          },
          "title": "Distributions",
          "type": "array"
        },
        "environment_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Environment Refs",
          "type": "array"
        },
        "independent_dimension": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Independent Dimension"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "protocol_ref": {
          "$ref": "#/$defs/ArtifactReference"
        },
        "samples": {
          "items": {
            "$ref": "#/$defs/BenchmarkSample"
          },
          "title": "Samples",
          "type": "array"
        },
        "scaling_assessments": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ScalingAssessment"
          },
          "title": "Scaling Assessments",
          "type": "array"
        },
        "scenario_series_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status": {
          "$ref": "#/$defs/BenchmarkStatus"
        }
      },
      "required": [
        "capability_gaps",
        "comparability_notes",
        "distributions",
        "environment_refs",
        "independent_dimension",
        "limitations",
        "protocol_ref",
        "samples",
        "scaling_assessments",
        "scenario_series_ref",
        "status"
      ],
      "title": "ExperimentSeriesPayload",
      "type": "object"
    },
    "MetricDistribution": {
      "additionalProperties": false,
      "properties": {
        "confidence_high": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence High"
        },
        "confidence_low": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence Low"
        },
        "excluded_count": {
          "minimum": 0,
          "title": "Excluded Count",
          "type": "integer"
        },
        "maximum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum"
        },
        "mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean"
        },
        "median": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Median"
        },
        "median_absolute_deviation": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Median Absolute Deviation"
        },
        "metric_key": {
          "title": "Metric Key",
          "type": "string"
        },
        "minimum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum"
        },
        "p95": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "P95"
        },
        "sample_count": {
          "minimum": 0,
          "title": "Sample Count",
          "type": "integer"
        },
        "standard_deviation": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Standard Deviation"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        }
      },
      "required": [
        "confidence_high",
        "confidence_low",
        "excluded_count",
        "maximum",
        "mean",
        "median",
        "median_absolute_deviation",
        "metric_key",
        "minimum",
        "p95",
        "sample_count",
        "standard_deviation",
        "unit"
      ],
      "title": "MetricDistribution",
      "type": "object"
    },
    "ProducerIdentity": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Build"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "build",
        "name",
        "version"
      ],
      "title": "ProducerIdentity",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "code_revision": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Revision"
        },
        "configuration_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivation_key": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Key"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "code_revision",
        "configuration_ref",
        "derivation_key",
        "input_refs",
        "notes"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "ScalingAssessment": {
      "additionalProperties": false,
      "properties": {
        "classification": {
          "$ref": "#/$defs/ScalingClassification"
        },
        "confidence": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "explanation": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Explanation",
          "type": "array"
        },
        "independent_dimension": {
          "title": "Independent Dimension",
          "type": "string"
        },
        "metric_key": {
          "title": "Metric Key",
          "type": "string"
        },
        "sample_points": {
          "default": 0,
          "minimum": 0,
          "title": "Sample Points",
          "type": "integer"
        },
        "slope": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Slope"
        },
        "transition_at": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transition At"
        }
      },
      "required": [
        "classification",
        "confidence",
        "explanation",
        "independent_dimension",
        "metric_key",
        "sample_points",
        "slope",
        "transition_at"
      ],
      "title": "ScalingAssessment",
      "type": "object"
    },
    "ScalingClassification": {
      "enum": [
        "approximately_constant",
        "approximately_linear",
        "superlinear",
        "sublinear",
        "threshold_transition",
        "inconclusive"
      ],
      "title": "ScalingClassification",
      "type": "string"
    }
  },
  "$id": "https://planguard.dev/schemas/planguard.experiment-series.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_kind": {
      "const": "experiment_series",
      "default": "experiment_series",
      "title": "Artifact Kind",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Extensions",
      "type": "object"
    },
    "payload": {
      "$ref": "#/$defs/ExperimentSeriesPayload"
    },
    "producer": {
      "$ref": "#/$defs/ProducerIdentity"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "planguard.experiment-series.v1",
      "default": "planguard.experiment-series.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "content_hash",
    "created_at",
    "extensions",
    "payload",
    "producer",
    "provenance",
    "schema_version"
  ],
  "title": "ExperimentSeriesArtifact",
  "type": "object"
}
