{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "schema_version": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        }
      },
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_hash",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "ProducerIdentity": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Build"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "build",
        "name",
        "version"
      ],
      "title": "ProducerIdentity",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "code_revision": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Revision"
        },
        "configuration_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivation_key": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Key"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "code_revision",
        "configuration_ref",
        "derivation_key",
        "input_refs",
        "notes"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "RoleBinding": {
      "additionalProperties": false,
      "properties": {
        "binding_kind": {
          "enum": [
            "model",
            "callable",
            "dataset",
            "value",
            "adapter",
            "opaque"
          ],
          "title": "Binding Kind",
          "type": "string"
        },
        "configuration": {
          "additionalProperties": true,
          "title": "Configuration",
          "type": "object"
        },
        "role_key": {
          "title": "Role Key",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "binding_kind",
        "configuration",
        "role_key",
        "target"
      ],
      "title": "RoleBinding",
      "type": "object"
    },
    "ScenarioBindingPayload": {
      "additionalProperties": false,
      "properties": {
        "adapter_key": {
          "title": "Adapter Key",
          "type": "string"
        },
        "application_key": {
          "title": "Application Key",
          "type": "string"
        },
        "binding_key": {
          "title": "Binding Key",
          "type": "string"
        },
        "capabilities": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Capabilities",
          "type": "array"
        },
        "role_bindings": {
          "items": {
            "$ref": "#/$defs/RoleBinding"
          },
          "title": "Role Bindings",
          "type": "array"
        },
        "tags": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "template_ref": {
          "$ref": "#/$defs/ArtifactReference"
        },
        "variant_bindings": {
          "items": {
            "$ref": "#/$defs/VariantBinding"
          },
          "title": "Variant Bindings",
          "type": "array"
        }
      },
      "required": [
        "adapter_key",
        "application_key",
        "binding_key",
        "capabilities",
        "role_bindings",
        "tags",
        "template_ref",
        "variant_bindings"
      ],
      "title": "ScenarioBindingPayload",
      "type": "object"
    },
    "VariantBinding": {
      "additionalProperties": false,
      "properties": {
        "configuration": {
          "additionalProperties": true,
          "title": "Configuration",
          "type": "object"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "variant_key": {
          "title": "Variant Key",
          "type": "string"
        }
      },
      "required": [
        "configuration",
        "target",
        "variant_key"
      ],
      "title": "VariantBinding",
      "type": "object"
    }
  },
  "$id": "https://planguard.dev/schemas/planguard.scenario-binding.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_kind": {
      "const": "scenario_binding",
      "default": "scenario_binding",
      "title": "Artifact Kind",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Extensions",
      "type": "object"
    },
    "payload": {
      "$ref": "#/$defs/ScenarioBindingPayload"
    },
    "producer": {
      "$ref": "#/$defs/ProducerIdentity"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "planguard.scenario-binding.v1",
      "default": "planguard.scenario-binding.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "content_hash",
    "created_at",
    "extensions",
    "payload",
    "producer",
    "provenance",
    "schema_version"
  ],
  "title": "ScenarioBindingArtifact",
  "type": "object"
}
