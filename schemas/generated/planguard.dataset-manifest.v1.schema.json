{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "schema_version": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        }
      },
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_hash",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "DatasetManifestPayload": {
      "additionalProperties": false,
      "properties": {
        "constraints": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "array"
        },
        "dataset_fingerprint": {
          "title": "Dataset Fingerprint",
          "type": "string"
        },
        "dataset_key": {
          "title": "Dataset Key",
          "type": "string"
        },
        "dataset_version": {
          "title": "Dataset Version",
          "type": "string"
        },
        "distributions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/DistributionSpec"
          },
          "title": "Distributions",
          "type": "array"
        },
        "entity_counts": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Entity Counts",
          "type": "object"
        },
        "generator_key": {
          "title": "Generator Key",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "scale_profile": {
          "title": "Scale Profile",
          "type": "string"
        },
        "seed": {
          "title": "Seed",
          "type": "integer"
        },
        "tenant_count": {
          "default": 1,
          "minimum": 1,
          "title": "Tenant Count",
          "type": "integer"
        }
      },
      "required": [
        "constraints",
        "dataset_fingerprint",
        "dataset_key",
        "dataset_version",
        "distributions",
        "entity_counts",
        "generator_key",
        "metadata",
        "scale_profile",
        "seed",
        "tenant_count"
      ],
      "title": "DatasetManifestPayload",
      "type": "object"
    },
    "DistributionSpec": {
      "additionalProperties": false,
      "properties": {
        "distribution_key": {
          "title": "Distribution Key",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "parameters": {
          "additionalProperties": true,
          "title": "Parameters",
          "type": "object"
        },
        "seed_offset": {
          "default": 0,
          "title": "Seed Offset",
          "type": "integer"
        }
      },
      "required": [
        "distribution_key",
        "kind",
        "parameters",
        "seed_offset"
      ],
      "title": "DistributionSpec",
      "type": "object"
    },
    "ProducerIdentity": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Build"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "build",
        "name",
        "version"
      ],
      "title": "ProducerIdentity",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "code_revision": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Revision"
        },
        "configuration_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivation_key": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Key"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "code_revision",
        "configuration_ref",
        "derivation_key",
        "input_refs",
        "notes"
      ],
      "title": "Provenance",
      "type": "object"
    }
  },
  "$id": "https://planguard.dev/schemas/planguard.dataset-manifest.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_kind": {
      "const": "dataset_manifest",
      "default": "dataset_manifest",
      "title": "Artifact Kind",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Extensions",
      "type": "object"
    },
    "payload": {
      "$ref": "#/$defs/DatasetManifestPayload"
    },
    "producer": {
      "$ref": "#/$defs/ProducerIdentity"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "planguard.dataset-manifest.v1",
      "default": "planguard.dataset-manifest.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "content_hash",
    "created_at",
    "extensions",
    "payload",
    "producer",
    "provenance",
    "schema_version"
  ],
  "title": "DatasetManifestArtifact",
  "type": "object"
}
