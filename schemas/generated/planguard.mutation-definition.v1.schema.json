{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "schema_version": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        }
      },
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_hash",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "MutationDefinitionPayload": {
      "additionalProperties": false,
      "properties": {
        "adapter_key": {
          "title": "Adapter Key",
          "type": "string"
        },
        "compatible_template_keys": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Compatible Template Keys",
          "type": "array"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "mutation_class": {
          "enum": [
            "application",
            "schema",
            "data",
            "runtime",
            "workload"
          ],
          "title": "Mutation Class",
          "type": "string"
        },
        "mutation_key": {
          "title": "Mutation Key",
          "type": "string"
        },
        "parameter_domain": {
          "additionalProperties": {
            "$ref": "#/$defs/ParameterDomain"
          },
          "title": "Parameter Domain",
          "type": "object"
        },
        "required_capabilities": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Required Capabilities",
          "type": "array"
        },
        "reversible": {
          "default": true,
          "title": "Reversible",
          "type": "boolean"
        },
        "title": {
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "adapter_key",
        "compatible_template_keys",
        "description",
        "mutation_class",
        "mutation_key",
        "parameter_domain",
        "required_capabilities",
        "reversible",
        "title"
      ],
      "title": "MutationDefinitionPayload",
      "type": "object"
    },
    "ParameterDomain": {
      "additionalProperties": false,
      "properties": {
        "constraints": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SelectorExpression"
          },
          "title": "Constraints",
          "type": "array"
        },
        "default": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default"
        },
        "kind": {
          "$ref": "#/$defs/ParameterDomainKind"
        },
        "maximum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum"
        },
        "minimum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum"
        },
        "partitions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ParameterPartition"
          },
          "title": "Partitions",
          "type": "array"
        },
        "registry_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Registry Key"
        },
        "step": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Step"
        },
        "values": {
          "default": [],
          "items": {},
          "title": "Values",
          "type": "array"
        }
      },
      "required": [
        "constraints",
        "default",
        "kind",
        "maximum",
        "minimum",
        "partitions",
        "registry_key",
        "step",
        "values"
      ],
      "title": "ParameterDomain",
      "type": "object"
    },
    "ParameterDomainKind": {
      "enum": [
        "finite",
        "integer_range",
        "float_range",
        "partitioned",
        "registry",
        "boolean",
        "opaque"
      ],
      "title": "ParameterDomainKind",
      "type": "string"
    },
    "ParameterPartition": {
      "additionalProperties": false,
      "properties": {
        "include_maximum": {
          "default": true,
          "title": "Include Maximum",
          "type": "boolean"
        },
        "include_minimum": {
          "default": true,
          "title": "Include Minimum",
          "type": "boolean"
        },
        "key": {
          "title": "Key",
          "type": "string"
        },
        "maximum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum"
        },
        "minimum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum"
        },
        "representative_values": {
          "default": [],
          "items": {},
          "title": "Representative Values",
          "type": "array"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        }
      },
      "required": [
        "include_maximum",
        "include_minimum",
        "key",
        "maximum",
        "minimum",
        "representative_values",
        "title"
      ],
      "title": "ParameterPartition",
      "type": "object"
    },
    "ProducerIdentity": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Build"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "build",
        "name",
        "version"
      ],
      "title": "ProducerIdentity",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "code_revision": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Revision"
        },
        "configuration_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivation_key": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Key"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "code_revision",
        "configuration_ref",
        "derivation_key",
        "input_refs",
        "notes"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "SelectorExpression": {
      "additionalProperties": false,
      "properties": {
        "children": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SelectorExpression"
          },
          "title": "Children",
          "type": "array"
        },
        "field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Field"
        },
        "operator": {
          "$ref": "#/$defs/SelectorOperator"
        },
        "value": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "children",
        "field",
        "operator",
        "value"
      ],
      "title": "SelectorExpression",
      "type": "object"
    },
    "SelectorOperator": {
      "enum": [
        "all",
        "any",
        "not",
        "equals",
        "not_equals",
        "greater_than",
        "greater_or_equal",
        "less_than",
        "less_or_equal",
        "contains",
        "exists",
        "in_set"
      ],
      "title": "SelectorOperator",
      "type": "string"
    }
  },
  "$id": "https://planguard.dev/schemas/planguard.mutation-definition.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_kind": {
      "const": "mutation_definition",
      "default": "mutation_definition",
      "title": "Artifact Kind",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Extensions",
      "type": "object"
    },
    "payload": {
      "$ref": "#/$defs/MutationDefinitionPayload"
    },
    "producer": {
      "$ref": "#/$defs/ProducerIdentity"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "planguard.mutation-definition.v1",
      "default": "planguard.mutation-definition.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "content_hash",
    "created_at",
    "extensions",
    "payload",
    "producer",
    "provenance",
    "schema_version"
  ],
  "title": "MutationDefinitionArtifact",
  "type": "object"
}
