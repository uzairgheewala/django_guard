{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "schema_version": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        }
      },
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_hash",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "ConstraintEvaluation": {
      "additionalProperties": false,
      "properties": {
        "constraint_key": {
          "title": "Constraint Key",
          "type": "string"
        },
        "explanation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Explanation"
        },
        "status": {
          "enum": [
            "satisfied",
            "not_satisfied",
            "unknown",
            "not_evaluated"
          ],
          "title": "Status",
          "type": "string"
        },
        "values": {
          "additionalProperties": true,
          "title": "Values",
          "type": "object"
        }
      },
      "required": [
        "constraint_key",
        "explanation",
        "status",
        "values"
      ],
      "title": "ConstraintEvaluation",
      "type": "object"
    },
    "ProducerIdentity": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Build"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "build",
        "name",
        "version"
      ],
      "title": "ProducerIdentity",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "code_revision": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Revision"
        },
        "configuration_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivation_key": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Key"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "code_revision",
        "configuration_ref",
        "derivation_key",
        "input_refs",
        "notes"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "WorkloadEpisodePayload": {
      "additionalProperties": false,
      "properties": {
        "constraint_evaluations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ConstraintEvaluation"
          },
          "title": "Constraint Evaluations",
          "type": "array"
        },
        "edge_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Edge Ids",
          "type": "array"
        },
        "family_scheme_key": {
          "title": "Family Scheme Key",
          "type": "string"
        },
        "match_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Match Confidence",
          "type": "number"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "motif_key": {
          "title": "Motif Key",
          "type": "string"
        },
        "node_bindings": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Node Bindings",
          "type": "object"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "subject_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Subject Refs",
          "type": "array"
        },
        "title": {
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "constraint_evaluations",
        "edge_ids",
        "family_scheme_key",
        "match_confidence",
        "metadata",
        "motif_key",
        "node_bindings",
        "run_id",
        "subject_refs",
        "title"
      ],
      "title": "WorkloadEpisodePayload",
      "type": "object"
    }
  },
  "$id": "https://planguard.dev/schemas/planguard.workload-episode.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_kind": {
      "const": "workload_episode",
      "default": "workload_episode",
      "title": "Artifact Kind",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Extensions",
      "type": "object"
    },
    "payload": {
      "$ref": "#/$defs/WorkloadEpisodePayload"
    },
    "producer": {
      "$ref": "#/$defs/ProducerIdentity"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "planguard.workload-episode.v1",
      "default": "planguard.workload-episode.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "content_hash",
    "created_at",
    "extensions",
    "payload",
    "producer",
    "provenance",
    "schema_version"
  ],
  "title": "WorkloadEpisodeArtifact",
  "type": "object"
}
