{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "schema_version": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        }
      },
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_hash",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "CorpusPromotionPayload": {
      "additionalProperties": false,
      "properties": {
        "candidate_ref": {
          "$ref": "#/$defs/ArtifactReference"
        },
        "minimization_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "promoted_artifact_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Promoted Artifact Refs",
          "type": "array"
        },
        "promotion_key": {
          "title": "Promotion Key",
          "type": "string"
        },
        "reviewer_notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Reviewer Notes",
          "type": "array"
        },
        "source_instance_ref": {
          "$ref": "#/$defs/ArtifactReference"
        },
        "status": {
          "$ref": "#/$defs/WorkflowStatus"
        },
        "target_collections": {
          "items": {
            "enum": [
              "detector_fixture",
              "scenario_corpus",
              "universe_profile",
              "mutation_registry",
              "golden_plan"
            ],
            "type": "string"
          },
          "title": "Target Collections",
          "type": "array"
        }
      },
      "required": [
        "candidate_ref",
        "minimization_ref",
        "promoted_artifact_refs",
        "promotion_key",
        "reviewer_notes",
        "source_instance_ref",
        "status",
        "target_collections"
      ],
      "title": "CorpusPromotionPayload",
      "type": "object"
    },
    "ProducerIdentity": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Build"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "build",
        "name",
        "version"
      ],
      "title": "ProducerIdentity",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "code_revision": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Revision"
        },
        "configuration_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivation_key": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Key"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "code_revision",
        "configuration_ref",
        "derivation_key",
        "input_refs",
        "notes"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "WorkflowStatus": {
      "enum": [
        "created",
        "running",
        "completed",
        "failed",
        "rejected"
      ],
      "title": "WorkflowStatus",
      "type": "string"
    }
  },
  "$id": "https://planguard.dev/schemas/planguard.corpus-promotion.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_kind": {
      "const": "corpus_promotion",
      "default": "corpus_promotion",
      "title": "Artifact Kind",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Extensions",
      "type": "object"
    },
    "payload": {
      "$ref": "#/$defs/CorpusPromotionPayload"
    },
    "producer": {
      "$ref": "#/$defs/ProducerIdentity"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "planguard.corpus-promotion.v1",
      "default": "planguard.corpus-promotion.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "content_hash",
    "created_at",
    "extensions",
    "payload",
    "producer",
    "provenance",
    "schema_version"
  ],
  "title": "CorpusPromotionArtifact",
  "type": "object"
}
