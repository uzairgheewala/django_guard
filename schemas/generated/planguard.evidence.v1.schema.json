{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "schema_version": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        }
      },
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_hash",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "EvidenceClaim": {
      "additionalProperties": false,
      "properties": {
        "claim_key": {
          "title": "Claim Key",
          "type": "string"
        },
        "explanation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Explanation"
        },
        "status": {
          "enum": [
            "supported",
            "contradicted",
            "unknown"
          ],
          "title": "Status",
          "type": "string"
        },
        "subject_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Subject Refs",
          "type": "array"
        },
        "values": {
          "additionalProperties": true,
          "title": "Values",
          "type": "object"
        }
      },
      "required": [
        "claim_key",
        "explanation",
        "status",
        "subject_refs",
        "values"
      ],
      "title": "EvidenceClaim",
      "type": "object"
    },
    "EvidencePayload": {
      "additionalProperties": false,
      "properties": {
        "claims": {
          "items": {
            "$ref": "#/$defs/EvidenceClaim"
          },
          "title": "Claims",
          "type": "array"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        }
      },
      "required": [
        "claims",
        "run_id"
      ],
      "title": "EvidencePayload",
      "type": "object"
    },
    "ProducerIdentity": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Build"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "build",
        "name",
        "version"
      ],
      "title": "ProducerIdentity",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "code_revision": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Revision"
        },
        "configuration_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivation_key": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Key"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "code_revision",
        "configuration_ref",
        "derivation_key",
        "input_refs",
        "notes"
      ],
      "title": "Provenance",
      "type": "object"
    }
  },
  "$id": "https://planguard.dev/schemas/planguard.evidence.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_kind": {
      "const": "evidence",
      "default": "evidence",
      "title": "Artifact Kind",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Extensions",
      "type": "object"
    },
    "payload": {
      "$ref": "#/$defs/EvidencePayload"
    },
    "producer": {
      "$ref": "#/$defs/ProducerIdentity"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "planguard.evidence.v1",
      "default": "planguard.evidence.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "content_hash",
    "created_at",
    "extensions",
    "payload",
    "producer",
    "provenance",
    "schema_version"
  ],
  "title": "EvidenceArtifact",
  "type": "object"
}
