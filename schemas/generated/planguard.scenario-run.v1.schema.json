{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "schema_version": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        }
      },
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_hash",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "OracleEvaluation": {
      "additionalProperties": false,
      "properties": {
        "evidence_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "expected_value": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Value"
        },
        "explanation": {
          "title": "Explanation",
          "type": "string"
        },
        "measured_value": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Measured Value"
        },
        "oracle_key": {
          "title": "Oracle Key",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/OracleStatus"
        }
      },
      "required": [
        "evidence_refs",
        "expected_value",
        "explanation",
        "measured_value",
        "oracle_key",
        "status"
      ],
      "title": "OracleEvaluation",
      "type": "object"
    },
    "OracleStatus": {
      "enum": [
        "satisfied",
        "not_satisfied",
        "unknown",
        "not_evaluated"
      ],
      "title": "OracleStatus",
      "type": "string"
    },
    "ProducerIdentity": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Build"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "build",
        "name",
        "version"
      ],
      "title": "ProducerIdentity",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "code_revision": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Revision"
        },
        "configuration_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivation_key": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Key"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "code_revision",
        "configuration_ref",
        "derivation_key",
        "input_refs",
        "notes"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "ScenarioReceiptStatus": {
      "enum": [
        "pending",
        "running",
        "succeeded",
        "failed",
        "skipped",
        "not_evaluated"
      ],
      "title": "ScenarioReceiptStatus",
      "type": "string"
    },
    "ScenarioRunPayload": {
      "additionalProperties": false,
      "properties": {
        "analysis_run_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "capability_gaps": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Capability Gaps",
          "type": "array"
        },
        "completed_at": {
          "format": "date-time",
          "title": "Completed At",
          "type": "string"
        },
        "dataset_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "oracle_evaluations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/OracleEvaluation"
          },
          "title": "Oracle Evaluations",
          "type": "array"
        },
        "phase_receipt_refs": {
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Phase Receipt Refs",
          "type": "array"
        },
        "result_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result Digest"
        },
        "scenario_instance_ref": {
          "$ref": "#/$defs/ArtifactReference"
        },
        "scenario_run_id": {
          "title": "Scenario Run Id",
          "type": "string"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "state_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "State Digest"
        },
        "status": {
          "$ref": "#/$defs/ScenarioReceiptStatus"
        },
        "variant_key": {
          "title": "Variant Key",
          "type": "string"
        }
      },
      "required": [
        "analysis_run_ref",
        "capability_gaps",
        "completed_at",
        "dataset_ref",
        "metadata",
        "oracle_evaluations",
        "phase_receipt_refs",
        "result_digest",
        "scenario_instance_ref",
        "scenario_run_id",
        "started_at",
        "state_digest",
        "status",
        "variant_key"
      ],
      "title": "ScenarioRunPayload",
      "type": "object"
    }
  },
  "$id": "https://planguard.dev/schemas/planguard.scenario-run.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_kind": {
      "const": "scenario_run",
      "default": "scenario_run",
      "title": "Artifact Kind",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Extensions",
      "type": "object"
    },
    "payload": {
      "$ref": "#/$defs/ScenarioRunPayload"
    },
    "producer": {
      "$ref": "#/$defs/ProducerIdentity"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "planguard.scenario-run.v1",
      "default": "planguard.scenario-run.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "content_hash",
    "created_at",
    "extensions",
    "payload",
    "producer",
    "provenance",
    "schema_version"
  ],
  "title": "ScenarioRunArtifact",
  "type": "object"
}
