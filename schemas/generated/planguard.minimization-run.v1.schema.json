{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "schema_version": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        }
      },
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_hash",
        "schema_version"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "MinimizationRunPayload": {
      "additionalProperties": false,
      "properties": {
        "candidate_ref": {
          "$ref": "#/$defs/ArtifactReference"
        },
        "capability_gaps": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Capability Gaps",
          "type": "array"
        },
        "explanation": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Explanation",
          "type": "array"
        },
        "minimized_complexity": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimized Complexity"
        },
        "minimized_instance_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "original_complexity": {
          "minimum": 0.0,
          "title": "Original Complexity",
          "type": "number"
        },
        "original_instance_ref": {
          "$ref": "#/$defs/ArtifactReference"
        },
        "preserved_predicate": {
          "$ref": "#/$defs/PreservedPredicate"
        },
        "status": {
          "$ref": "#/$defs/WorkflowStatus"
        },
        "steps": {
          "default": [],
          "items": {
            "$ref": "#/$defs/MinimizationStep"
          },
          "title": "Steps",
          "type": "array"
        }
      },
      "required": [
        "candidate_ref",
        "capability_gaps",
        "explanation",
        "minimized_complexity",
        "minimized_instance_ref",
        "original_complexity",
        "original_instance_ref",
        "preserved_predicate",
        "status",
        "steps"
      ],
      "title": "MinimizationRunPayload",
      "type": "object"
    },
    "MinimizationStep": {
      "additionalProperties": false,
      "properties": {
        "after": {
          "additionalProperties": true,
          "title": "After",
          "type": "object"
        },
        "before": {
          "additionalProperties": true,
          "title": "Before",
          "type": "object"
        },
        "explanation": {
          "title": "Explanation",
          "type": "string"
        },
        "mutation": {
          "title": "Mutation",
          "type": "string"
        },
        "predicate_preserved": {
          "title": "Predicate Preserved",
          "type": "boolean"
        },
        "step_index": {
          "minimum": 0,
          "title": "Step Index",
          "type": "integer"
        }
      },
      "required": [
        "after",
        "before",
        "explanation",
        "mutation",
        "predicate_preserved",
        "step_index"
      ],
      "title": "MinimizationStep",
      "type": "object"
    },
    "PreservedPredicate": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "title": "Description",
          "type": "string"
        },
        "kind": {
          "enum": [
            "finding_present",
            "finding_absent",
            "policy_failed",
            "policy_passed",
            "plan_transition",
            "oracle_failed",
            "custom"
          ],
          "title": "Kind",
          "type": "string"
        },
        "parameters": {
          "additionalProperties": true,
          "title": "Parameters",
          "type": "object"
        },
        "predicate_key": {
          "title": "Predicate Key",
          "type": "string"
        },
        "subject_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "description",
        "kind",
        "parameters",
        "predicate_key",
        "subject_ref"
      ],
      "title": "PreservedPredicate",
      "type": "object"
    },
    "ProducerIdentity": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Build"
        },
        "name": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "build",
        "name",
        "version"
      ],
      "title": "ProducerIdentity",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "code_revision": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Revision"
        },
        "configuration_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivation_key": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Derivation Key"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactReference"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "notes": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "code_revision",
        "configuration_ref",
        "derivation_key",
        "input_refs",
        "notes"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "WorkflowStatus": {
      "enum": [
        "created",
        "running",
        "completed",
        "failed",
        "rejected"
      ],
      "title": "WorkflowStatus",
      "type": "string"
    }
  },
  "$id": "https://planguard.dev/schemas/planguard.minimization-run.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_kind": {
      "const": "minimization_run",
      "default": "minimization_run",
      "title": "Artifact Kind",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Extensions",
      "type": "object"
    },
    "payload": {
      "$ref": "#/$defs/MinimizationRunPayload"
    },
    "producer": {
      "$ref": "#/$defs/ProducerIdentity"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "planguard.minimization-run.v1",
      "default": "planguard.minimization-run.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "content_hash",
    "created_at",
    "extensions",
    "payload",
    "producer",
    "provenance",
    "schema_version"
  ],
  "title": "MinimizationRunArtifact",
  "type": "object"
}
